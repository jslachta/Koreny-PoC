@page "/"
@using Koreny.Models
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject GedcomParser Parser
@inject AppState AppState
@inject IJSRuntime JSRuntime

<PageTitle>Kořeny</PageTitle>

<main style="width: 100%; max-width: none; margin: 0 auto; padding: 1rem;">
    <h1>
      <svg viewBox="0 0 100 100" width="40" height="40"
           style="vertical-align:middle;margin-right:8px"
           xmlns="http://www.w3.org/2000/svg">
        <rect width="100" height="100" rx="16" fill="#2D5A3D"/>
        <rect x="46" y="38" width="8" height="28" rx="2" fill="#E8D5A3"/>
        <line x1="50" y1="42" x2="30" y2="24" stroke="#E8D5A3" stroke-width="4" stroke-linecap="round"/>
        <line x1="50" y1="42" x2="70" y2="24" stroke="#E8D5A3" stroke-width="4" stroke-linecap="round"/>
        <line x1="50" y1="50" x2="22" y2="38" stroke="#E8D5A3" stroke-width="3" stroke-linecap="round"/>
        <line x1="50" y1="50" x2="78" y2="38" stroke="#E8D5A3" stroke-width="3" stroke-linecap="round"/>
        <line x1="50" y1="66" x2="30" y2="82" stroke="#E8D5A3" stroke-width="4" stroke-linecap="round"/>
        <line x1="50" y1="66" x2="70" y2="82" stroke="#E8D5A3" stroke-width="4" stroke-linecap="round"/>
        <line x1="50" y1="66" x2="20" y2="72" stroke="#E8D5A3" stroke-width="3" stroke-linecap="round"/>
        <line x1="50" y1="66" x2="80" y2="72" stroke="#E8D5A3" stroke-width="3" stroke-linecap="round"/>
        <line x1="50" y1="66" x2="50" y2="84" stroke="#E8D5A3" stroke-width="3" stroke-linecap="round"/>
      </svg>
      Kořeny
    </h1>

    @if (!string.IsNullOrEmpty(_loadError))
    {
        <p role="alert">@_loadError</p>
    }

    <div style="display: flex; width: 100%; gap: 1rem; align-items: stretch;">
        <div style="flex: 3; min-width: 0; display: flex; flex-direction: column;">
            @* Three-row toolbar: file / view / stats; hr separates rows without adding controls. *@
            <div style="margin-bottom: 0.75rem;">
                <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;">
                    <InputFile id="gedcomInput" OnChange="OnFileSelectedAsync" style="display:none" accept=".ged" />
                    <button type="button" onclick="document.getElementById('gedcomInput').click()">Načíst GEDCOM</button>
                    <span aria-hidden="true">|</span>
                    <button type="button" @onclick="ExportGedcomAsync" disabled="@(_doc is null)">Uložit GEDCOM</button>
                </div>
                <hr style="margin: 0.5rem 0; border: 0; border-top: 1px solid #ccc;" />
                <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;">
                    <button type="button" @onclick="OpenFullTreeOverlay" disabled="@(_doc is null || string.IsNullOrEmpty(_rootPersonId))">Celý strom</button>
                    <span aria-hidden="true">|</span>
                    <button type="button" @onclick="OpenFullGraphOverlayAsync" disabled="@(_doc is null)">Celý graf</button>
                    <span aria-hidden="true">|</span>
                    <button type="button" @onclick="DownloadToolbarSvgAsync" disabled="@(_doc is null)">Stáhnout SVG</button>
                    <span aria-hidden="true">|</span>
                    <button type="button" @onclick="PrintToolbarSvgAsync" disabled="@(_doc is null)">Tisk</button>
                </div>
                <hr style="margin: 0.5rem 0; border: 0; border-top: 1px solid #ccc;" />
                @if (_doc is not null)
                {
                    <span role="status">Osoby: @_doc.Individuals.Count, rodiny: @_doc.Families.Count</span>
                }
            </div>

            @if (_doc is not null)
            {
                <HourglassTree Document="@_doc"
                               RootPersonId="@_rootPersonId"
                               OnPersonSelected="OnTreePersonSelected"
                               OnPersonDoubleClicked="OnTreePersonDoubleClicked" />
            }
        </div>

        <aside style="flex: 2; min-width: 0; border-left: 1px solid #ccc; padding-left: 1rem; display: flex; flex-direction: column; min-height: 0; max-height: calc(100vh - 7rem);">
            <div style="display: flex; flex-direction: column; flex: 1; min-height: 0;">
                @switch (_panel)
                {
                    case PanelView.None:
                        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; flex-shrink: 0;">
                            <button type="button" @onclick="StartNewPerson" disabled="@(_doc is null)">Nová osoba</button>
                            <span aria-hidden="true">|</span>
                            <button type="button" @onclick="StartNewFamily" disabled="@(_doc is null)">Nová rodina</button>
                        </div>
                        <hr style="margin: 0.5rem 0; border: 0; border-top: 1px solid #ccc;" />
                        @if (_doc is not null)
                        {
                            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; flex-shrink: 0;">
                                <label for="fam-pick" style="margin: 0;">Upravit rodinu:</label>
                                <select id="fam-pick" @bind="_pickFamilyId" disabled="@(_doc.Families.Count == 0)">
                                    @for (var fi = 0; fi < _doc.Families.Count; fi++)
                                    {
                                        var f = _doc.Families[fi];
                                        <option value="@f.Id">@FamilyLabel(f, fi + 1)</option>
                                    }
                                </select>
                                <button type="button" @onclick="OpenPickedFamilyForEdit" disabled="@(_doc.Families.Count == 0 || string.IsNullOrEmpty(_pickFamilyId))">Otevřít</button>
                            </div>
                            <hr style="margin: 0.5rem 0; border: 0; border-top: 1px solid #ccc;" />
                        }
                        <p style="margin-top: 0; flex-shrink: 0;">Vyberte osobu nebo přidejte novou.</p>
                        <div style="flex: 1; min-height: 0; overflow: auto;">
                            @if (_doc is not null)
                            {
                                @foreach (var p in GetIndividualsSorted())
                                {
                                    var rowId = p.Id;
                                    <button type="button"
                                            @onclick="@(() => OnPersonListRowClicked(rowId))"
                                            style="display: block; width: 100%; text-align: left; margin-bottom: 0.35rem; cursor: pointer;">
                                        @p.FullName — @FormatLifespanYears(p)
                                    </button>
                                }
                            }
                        </div>
                        break;
                    case PanelView.Person:
                        <div style="display: flex; flex-direction: column; flex: 1; min-height: 0;">
                            <h2 style="margin-top: 0;">@(_personIsNew ? "Nová osoba" : "Upravit osobu")</h2>
                            <div style="flex: 1; overflow: auto; min-height: 0;">
                                <div style="display: grid; gap: 0.5rem;">
                                    <label>Jméno <input @bind="_personForm.Given" /></label>
                                    <label>Příjmení <input @bind="_personForm.Surname" /></label>
                                    <label>
                                        Pohlaví
                                        <select @bind="_personForm.SexCode">
                                            <option value="0">Neznámé</option>
                                            <option value="1">Muž</option>
                                            <option value="2">Žena</option>
                                        </select>
                                    </label>
                                    <label>Datum narození <input @bind="_personForm.BirthDate" placeholder="např. 3 MAR 1901" /></label>
                                    <label>Místo narození <input @bind="_personForm.BirthPlace" /></label>
                                    <label>Datum úmrtí <input @bind="_personForm.DeathDate" placeholder="např. 1 MAR 1980" /></label>
                                    <label>Místo úmrtí <input @bind="_personForm.DeathPlace" /></label>
                                    <label>Poznámka <input @bind="_personForm.NoteFirst" /></label>
                                </div>
                            </div>
                            <div style="margin-top: 0.75rem; flex-shrink: 0;">
                                <button type="button" @onclick="SavePerson">Uložit</button>
                                @if (!_personIsNew)
                                {
                                    <button type="button" @onclick="DeletePerson">Smazat</button>
                                }
                                <button type="button" @onclick="CancelPanel">Zrušit</button>
                            </div>
                        </div>
                        break;
                    case PanelView.Family:
                        <div style="display: flex; flex-direction: column; flex: 1; min-height: 0;">
                            <h2 style="margin-top: 0;">@(_familyIsNew ? "Nová rodina" : "Upravit rodinu")</h2>
                            @if (_doc is null || _doc.Individuals.Count == 0)
                            {
                                <p>Nejdříve přidejte alespoň jednu osobu.</p>
                                <div style="margin-top: 0.75rem; flex-shrink: 0;">
                                    <button type="button" @onclick="CancelPanel">Zpět</button>
                                </div>
                            }
                            else
                            {
                                <div style="flex: 1; overflow: auto; min-height: 0;">
                                    <div style="display: grid; gap: 0.5rem;">
                                        <label>
                                            Manžel
                                            <select @bind="_familyForm.HusbandId">
                                                <option value="">(žádný)</option>
                                                @foreach (var p in _doc.Individuals)
                                                {
                                                    <option value="@p.Id">@p.FullName (@p.Id)</option>
                                                }
                                            </select>
                                        </label>
                                        <label>
                                            Manželka
                                            <select @bind="_familyForm.WifeId">
                                                <option value="">(žádná)</option>
                                                @foreach (var p in _doc.Individuals)
                                                {
                                                    <option value="@p.Id">@p.FullName (@p.Id)</option>
                                                }
                                            </select>
                                        </label>
                                        <fieldset>
                                            <legend>Děti</legend>
                                            @foreach (var c in _doc.Individuals)
                                            {
                                                var cid = c.Id;
                                                <label style="display: block;">
                                                    <input type="checkbox" checked="@IsFamilyChildChecked(cid)" @onchange="@(e => OnFamilyChildToggle(cid, e))" />
                                                    @c.FullName (@cid)
                                                </label>
                                            }
                                        </fieldset>
                                        <label>Datum sňatku <input @bind="_familyForm.MarriageDate" placeholder="např. 15 JUN 1925" /></label>
                                        <label>Místo sňatku <input @bind="_familyForm.MarriagePlace" /></label>
                                    </div>
                                </div>
                                <div style="margin-top: 0.75rem; flex-shrink: 0;">
                                    <button type="button" @onclick="SaveFamily">Uložit</button>
                                    @if (!_familyIsNew)
                                    {
                                        <button type="button" @onclick="DeleteFamily">Smazat</button>
                                    }
                                    <button type="button" @onclick="CancelPanel">Zrušit</button>
                                </div>
                            }
                        </div>
                        break;
                }
            </div>
        </aside>
    </div>
</main>

@if (_showFullTreeOverlay && _doc is not null)
{
    <div style="position: fixed; inset: 0; z-index: 1000; background: #fff; outline: none;"
         tabindex="-1"
         @ref="_fullTreeOverlayRef"
         @onkeydown="OnFullTreeKeyDown">
        @* SVG export/tisk zde není: f3 SVG nese zoom transformace a rozměry viewportu,
           serializace z DOM by exportovala jen aktuální výřez (known limitation, session 4). *@
        <div style="position: absolute; top: 0.5rem; right: 0.5rem; z-index: 1001; display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; justify-content: flex-end;">
            <button type="button"
                    @onclick="CloseFullTreeOverlay"
                    aria-label="Zavřít">×</button>
        </div>
        <div style="position: absolute; inset: 0; padding: 0;">
            <F3Tree Document="@_doc"
                    RootPersonId="@_rootPersonId"
                    OnPersonSelected="OnOverlayPersonSelected" />
        </div>
    </div>
}

@if (_showFullGraphOverlay && !string.IsNullOrEmpty(_fullGraphSvgDataUri))
{
    <div style="position: fixed; inset: 0; z-index: 1000; background: #fff; outline: none;"
         tabindex="-1"
         @ref="_fullGraphOverlayRef"
         @onkeydown="OnFullGraphKeyDown">
        <div style="position: absolute; top: 0.5rem; right: 0.5rem; z-index: 1001; display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; justify-content: flex-end;">
            <button type="button" @onclick="DownloadFullGraphSvgAsync">Stáhnout SVG</button>
            <button type="button" @onclick="PrintFullGraphSvgAsync">Tisk</button>
            <button type="button"
                    @onclick="CloseFullGraphOverlay"
                    aria-label="Zavřít">×</button>
        </div>
        <div style="position: absolute; inset: 0; overflow: auto; display: flex; justify-content: center; align-items: flex-start; padding: 2.5rem 0.75rem 0.75rem 0.75rem;">
            <img src="@_fullGraphSvgDataUri" alt="Rodinný graf" style="display: block; max-width: none;" />
        </div>
    </div>
}

@code {
    private GedcomDocument? _doc;
    private string? _loadError;
    private string? _rootPersonId;

    private PanelView _panel = PanelView.None;
    private bool _personIsNew;
    private bool _familyIsNew;
    private string? _editPersonId;
    private string? _editFamilyId;

    private PersonFormState _personForm = new();

    private FamilyFormState _familyForm = new();
    private readonly Dictionary<string, bool> _fChildSel = new(StringComparer.Ordinal);
    private string _pickFamilyId = string.Empty;

    private bool _showFullTreeOverlay;
    private ElementReference _fullTreeOverlayRef;
    private bool _pendingFullTreeOverlayFocus;

    private bool _showFullGraphOverlay;
    private string? _fullGraphSvgMarkup;
    private string? _fullGraphSvgDataUri;
    private ElementReference _fullGraphOverlayRef;
    private bool _pendingFullGraphOverlayFocus;

    private IJSObjectReference? _exportModule;

    private enum PanelView
    {
        None,
        Person,
        Family,
    }

    protected override void OnInitialized()
    {
        AppState.Document ??= new GedcomDocument();
        _doc = AppState.Document;
        EnsureRootPersonId();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingFullTreeOverlayFocus && _showFullTreeOverlay)
        {
            _pendingFullTreeOverlayFocus = false;
            await _fullTreeOverlayRef.FocusAsync();
        }

        if (_pendingFullGraphOverlayFocus && _showFullGraphOverlay)
        {
            _pendingFullGraphOverlayFocus = false;
            await _fullGraphOverlayRef.FocusAsync();
        }
    }

    private void OpenFullTreeOverlay()
    {
        if (_doc is null || string.IsNullOrEmpty(_rootPersonId))
        {
            return;
        }

        _showFullTreeOverlay = true;
        _pendingFullTreeOverlayFocus = true;
    }

    private void CloseFullTreeOverlay()
    {
        _showFullTreeOverlay = false;
    }

    /// <summary>Klik na osobu v f3 overlayi: přepne kořen a overlay zavře (stejné chování jako klik v HourglassTree).</summary>
    private Task OnOverlayPersonSelected(string id)
    {
        _rootPersonId = id;
        CloseFullTreeOverlay();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void OnFullTreeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            CloseFullTreeOverlay();
        }
    }

    private async Task OpenFullGraphOverlayAsync()
    {
        if (_doc is null)
        {
            return;
        }

        var svg = await FullGraph.RenderToSvgAsync(_doc, JSRuntime);
        _fullGraphSvgMarkup = svg;
        _fullGraphSvgDataUri = "data:image/svg+xml;base64," + Convert.ToBase64String(Encoding.UTF8.GetBytes(svg));
        _showFullGraphOverlay = true;
        _pendingFullGraphOverlayFocus = true;
    }

    private void CloseFullGraphOverlay()
    {
        _showFullGraphOverlay = false;
        _fullGraphSvgMarkup = null;
        _fullGraphSvgDataUri = null;
    }

    private async Task DownloadFullGraphSvgAsync()
    {
        if (string.IsNullOrEmpty(_fullGraphSvgMarkup))
        {
            return;
        }

        var module = await GetExportModuleAsync();
        await module.InvokeVoidAsync("downloadSvg", _fullGraphSvgMarkup, "koreny-export.svg");
    }

    private async Task PrintFullGraphSvgAsync()
    {
        if (string.IsNullOrEmpty(_fullGraphSvgMarkup))
        {
            return;
        }

        var module = await GetExportModuleAsync();
        await module.InvokeVoidAsync("printSvg", _fullGraphSvgMarkup);
    }

    private void OnFullGraphKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            CloseFullGraphOverlay();
        }
    }

    /// <summary>Toolbar export kreslí celý graf (FullGraph); potomkovský strom je nyní živá f3 komponenta bez SVG exportu.</summary>
    private async Task DownloadToolbarSvgAsync()
    {
        if (_doc is null)
        {
            return;
        }

        var svg = await FullGraph.RenderToSvgAsync(_doc, JSRuntime);
        var module = await GetExportModuleAsync();
        await module.InvokeVoidAsync("downloadSvg", svg, "koreny-export.svg");
    }

    private async Task PrintToolbarSvgAsync()
    {
        if (_doc is null)
        {
            return;
        }

        var svg = await FullGraph.RenderToSvgAsync(_doc, JSRuntime);
        var module = await GetExportModuleAsync();
        await module.InvokeVoidAsync("printSvg", svg);
    }

    private void EnsureRootPersonId()
    {
        _doc = AppState.Document;
        if (_doc is null || _doc.Individuals.Count == 0)
        {
            _rootPersonId = null;
            return;
        }

        if (string.IsNullOrEmpty(_rootPersonId) || _doc.Individuals.All(x => x.Id != _rootPersonId))
        {
            _rootPersonId = _doc.Individuals[0].Id;
        }
    }

    private string FamilyLabel(GedcomFamily family, int index)
    {
        if (_doc is null)
        {
            return $"{index}. —";
        }

        static string PartnerLabel(GedcomIndividual ind)
        {
            var g = ind.Name?.GivenName;
            var s = ind.Name?.Surname;
            var givenOk = !string.IsNullOrWhiteSpace(g);
            var surOk = !string.IsNullOrWhiteSpace(s);

            if (!givenOk && !surOk)
            {
                return "?";
            }

            if (!givenOk && surOk)
            {
                var sTrim = s!.Trim();
                return $"? {char.ToUpperInvariant(sTrim[0])}.";
            }

            if (givenOk && !surOk)
            {
                return g!.Trim();
            }

            var given = g!.Trim();
            var sTr = s!.Trim();
            return $"{given} {char.ToUpperInvariant(sTr[0])}.";
        }

        GedcomIndividual? Find(string? id)
        {
            if (string.IsNullOrEmpty(id))
            {
                return null;
            }

            foreach (var i in _doc.Individuals)
            {
                if (i.Id == id)
                {
                    return i;
                }
            }

            return null;
        }

        var parts = new List<string>();
        var h = Find(family.HusbandId);
        if (h is not null)
        {
            parts.Add(PartnerLabel(h));
        }

        var w = Find(family.WifeId);
        if (w is not null)
        {
            parts.Add(PartnerLabel(w));
        }

        var core = parts.Count switch
        {
            0 => "—",
            1 => parts[0],
            _ => string.Join(" + ", parts),
        };

        return $"{index}. {core}";
    }

    private Task OnTreePersonSelected(string id)
    {
        _rootPersonId = id;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task OnTreePersonDoubleClicked(string id)
    {
        _rootPersonId = id;
        OpenPersonForEdit(id);
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void OnPersonListRowClicked(string id)
    {
        _rootPersonId = id;
        OpenPersonForEdit(id);
        StateHasChanged();
    }

    private IEnumerable<GedcomIndividual> GetIndividualsSorted()
    {
        if (_doc is null)
        {
            return Enumerable.Empty<GedcomIndividual>();
        }

        return _doc.Individuals
            .OrderBy(p => p.Name?.Surname ?? "", StringComparer.OrdinalIgnoreCase)
            .ThenBy(p => p.Name?.GivenName ?? "", StringComparer.OrdinalIgnoreCase);
    }

    private static string FormatLifespanYears(GedcomIndividual i)
    {
        var b = i.Birth?.ParsedYear;
        var d = i.Death?.ParsedYear;
        if (b is not null && d is not null)
        {
            return $"{b}–{d}";
        }

        if (b is not null)
        {
            return $"{b}–";
        }

        if (d is not null)
        {
            return $"–{d}";
        }

        return "?";
    }

    private void StartNewPerson()
    {
        if (_doc is null)
        {
            return;
        }

        _panel = PanelView.Person;
        _personIsNew = true;
        _editPersonId = null;
        _personForm = new PersonFormState();
    }

    private void OpenPersonForEdit(string id)
    {
        if (_doc is null)
        {
            return;
        }

        _panel = PanelView.Person;
        _personIsNew = false;
        _editPersonId = id;
        var p = _doc.Individuals.First(x => x.Id == id);
        _personForm = new PersonFormState();
        _personForm.Fill(p);
    }

    private void SavePerson()
    {
        if (_doc is null)
        {
            return;
        }

        GedcomIndividual ind;
        if (_personIsNew)
        {
            ind = new GedcomIndividual { Id = NextIndividualId() };
            _doc.Individuals.Add(ind);
        }
        else
        {
            if (string.IsNullOrEmpty(_editPersonId))
            {
                return;
            }

            ind = _doc.Individuals.First(x => x.Id == _editPersonId);
        }

        _personForm.ApplyTo(ind);
        GedcomSync.SyncIndividual(_doc, ind);
        _doc.InvalidateLookups();
        _panel = PanelView.None;
        EnsureRootPersonId();
        StateHasChanged();
    }

    private void DeletePerson()
    {
        if (_doc is null || _personIsNew || string.IsNullOrEmpty(_editPersonId))
        {
            return;
        }

        var ind = _doc.Individuals.FirstOrDefault(x => x.Id == _editPersonId);
        StripIndividualFromFamilies(_editPersonId);
        _doc.Individuals.RemoveAll(x => x.Id == _editPersonId);
        if (ind is not null)
        {
            GedcomSync.RemoveIndividualNode(_doc, ind);
        }

        _doc.InvalidateLookups();
        if (_rootPersonId == _editPersonId)
        {
            _rootPersonId = null;
        }

        _panel = PanelView.None;
        EnsureRootPersonId();
        StateHasChanged();
    }

    private static void StripIndividualFromFamilies(string personId, GedcomDocument doc)
    {
        foreach (var f in doc.Families)
        {
            if (f.HusbandId == personId)
            {
                f.HusbandId = null;
            }

            if (f.WifeId == personId)
            {
                f.WifeId = null;
            }

            f.ChildrenIds.RemoveAll(c => c == personId);
        }
    }

    private void StripIndividualFromFamilies(string personId) =>
        StripIndividualFromFamilies(personId, _doc!);

    private void StartNewFamily()
    {
        _panel = PanelView.Family;
        _familyIsNew = true;
        _editFamilyId = null;
        ClearFamilyForm();
    }

    private void OpenPickedFamilyForEdit()
    {
        if (string.IsNullOrEmpty(_pickFamilyId))
        {
            return;
        }

        OpenFamilyForEdit(_pickFamilyId);
        StateHasChanged();
    }

    private void OpenFamilyForEdit(string id)
    {
        if (_doc is null)
        {
            return;
        }

        var f = _doc.Families.First(x => x.Id == id);
        _panel = PanelView.Family;
        _familyIsNew = false;
        _editFamilyId = id;
        _pickFamilyId = id;
        _familyForm = new FamilyFormState();
        _familyForm.Fill(f);
        _fChildSel.Clear();
        foreach (var p in _doc.Individuals)
        {
            _fChildSel[p.Id] = f.ChildrenIds.Contains(p.Id);
        }
    }

    private void ClearFamilyForm()
    {
        _familyForm = new FamilyFormState();
        _fChildSel.Clear();
        if (_doc is not null)
        {
            foreach (var p in _doc.Individuals)
            {
                _fChildSel[p.Id] = false;
            }
        }
    }

    private bool IsFamilyChildChecked(string id) =>
        _fChildSel.TryGetValue(id, out var v) && v;

    private void OnFamilyChildToggle(string id, ChangeEventArgs e)
    {
        if (e.Value is bool on)
        {
            _fChildSel[id] = on;
        }
    }

    private void SaveFamily()
    {
        if (_doc is null || _doc.Individuals.Count == 0)
        {
            return;
        }

        GedcomFamily fam;
        if (_familyIsNew)
        {
            fam = new GedcomFamily { Id = NextFamilyId() };
            _doc.Families.Add(fam);
        }
        else
        {
            if (string.IsNullOrEmpty(_editFamilyId))
            {
                return;
            }

            fam = _doc.Families.First(x => x.Id == _editFamilyId);
        }

        // Vybrané děti v pořadí seznamu osob; SyncFamily zachová pořadí existujících CHIL uzlů.
        _familyForm.ChildIds = _doc.Individuals
            .Where(p => _fChildSel.TryGetValue(p.Id, out var on) && on)
            .Select(p => p.Id)
            .ToList();
        _familyForm.ApplyTo(fam);

        GedcomSync.SyncFamily(_doc, fam);
        _doc.InvalidateLookups();
        _panel = PanelView.None;
        StateHasChanged();
    }

    private void DeleteFamily()
    {
        if (_doc is null || _familyIsNew || string.IsNullOrEmpty(_editFamilyId))
        {
            return;
        }

        var fam = _doc.Families.FirstOrDefault(x => x.Id == _editFamilyId);
        _doc.Families.RemoveAll(x => x.Id == _editFamilyId);
        if (fam is not null)
        {
            GedcomSync.RemoveFamilyNode(_doc, fam);
        }

        _doc.InvalidateLookups();
        _panel = PanelView.None;
        StateHasChanged();
    }

    private void CancelPanel()
    {
        _panel = PanelView.None;
    }

    private string NextIndividualId()
    {
        var max = 0;
        foreach (var i in _doc!.Individuals)
        {
            if (i.Id.Length > 1 && i.Id[0] == 'I' && int.TryParse(i.Id.AsSpan(1), out var n))
            {
                max = Math.Max(max, n);
            }
        }

        return $"I{max + 1}";
    }

    private string NextFamilyId()
    {
        var max = 0;
        foreach (var f in _doc!.Families)
        {
            if (f.Id.Length > 1 && f.Id[0] == 'F' && int.TryParse(f.Id.AsSpan(1), out var n))
            {
                max = Math.Max(max, n);
            }
        }

        return $"F{max + 1}";
    }

    private async Task OnFileSelectedAsync(InputFileChangeEventArgs e)
    {
        _loadError = null;
        var file = e.File;
        if (file is null)
        {
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 50_000_000);
            using var reader = new StreamReader(stream, Encoding.UTF8);
            var text = await reader.ReadToEndAsync();
            AppState.Document = Parser.Parse(text);
            _doc = AppState.Document;
            _panel = PanelView.None;
            EnsureRootPersonId();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
    }

    private async Task ExportGedcomAsync()
    {
        if (_doc is null)
        {
            return;
        }

        var text = GedcomWriter.Write(_doc);
        var module = await GetExportModuleAsync();
        await module.InvokeVoidAsync("downloadText", text, "koreny-export.ged", "text/plain;charset=utf-8");
    }

    private async ValueTask<IJSObjectReference> GetExportModuleAsync()
    {
        if (_exportModule is not null)
        {
            return _exportModule;
        }

        _exportModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/export.js");
        return _exportModule;
    }

    public async ValueTask DisposeAsync()
    {
        if (_exportModule is not null)
        {
            await _exportModule.DisposeAsync();
            _exportModule = null;
        }
    }
}
