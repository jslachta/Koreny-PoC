@using Koreny.Models
@using Koreny.Services
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS

@* Živý rodokmen na knihovně Topola (Relatives chart). Data mapuje TopolaDataMapper,
   interop (render + d3.zoom + export) drží js/topola-view.js. *@

<div id="@_elementId" style="width: 100%; height: 100%;"></div>

@code {
    private readonly string _elementId = $"topola-tree-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private DotNetObjectReference<TopolaTree>? _selfRef;
    private bool _initialized;

    [Parameter]
    public GedcomDocument? Document { get; set; }

    [Parameter]
    public string? RootPersonId { get; set; }

    [Parameter]
    public EventCallback<string> OnPersonSelected { get; set; }

    /// <summary>Vyvolá se po dokončení initu (strom stojí, lze exportovat) — pro skrytý download z toolbaru.</summary>
    [Parameter]
    public EventCallback OnReady { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || Document is null || Document.Individuals.Count == 0)
        {
            return;
        }

        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/topola-view.js");
        _selfRef = DotNetObjectReference.Create(this);
        var json = TopolaDataMapper.ToJson(Document);
        await _module.InvokeVoidAsync("init", _elementId, json, RootPersonId, _selfRef);
        _initialized = true;

        if (OnReady.HasDelegate)
        {
            await OnReady.InvokeAsync();
        }
    }

    [JSInvokable]
    public Task OnPersonClicked(string id) => OnPersonSelected.InvokeAsync(id);

    /// <summary>Samostatné SVG celého rodokmenu (nezávislé na pan/zoom); null, dokud strom nestojí.</summary>
    public async Task<string?> ExportSvgAsync()
    {
        if (_module is null || !_initialized)
        {
            return null;
        }

        return await _module.InvokeAsync<string>("exportSvg", _elementId);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module is not null)
            {
                if (_initialized)
                {
                    await _module.InvokeVoidAsync("destroy", _elementId);
                }

                await _module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException)
        {
            // Okruh je pryč (reload/zavření) — JS strana zmizela i s DOM, není co uklízet.
        }

        _selfRef?.Dispose();
        _selfRef = null;
        _module = null;
    }
}
