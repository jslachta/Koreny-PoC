@using System.Text
@using System.Text.Json
@using Koreny.Models
@using Microsoft.JSInterop

@inject IJSRuntime JS

@* Virtual family nodes (F…) separate marriage from parent/child ranks so Dagre does not treat spouses as parent/child. *@

@code {
    public const double NODE_WIDTH = 160;
    public const double NODE_HEIGHT = 56;
    private const double FamilyNodeSize = 8;
    private const double FamilyDotR = 4;
    private const double Padding = 24;
    private const double NameLineY = 22;
    private const double LifespanLineY = 42;
    private const int MaxNameChars = 26;

    private static readonly JsonSerializerOptions JsonOpts = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        PropertyNameCaseInsensitive = true,
    };

    [Parameter]
    public GedcomDocument? Document { get; set; }

    /// <summary>Uses injected <see cref="IJSRuntime"/> when <see cref="Document"/> is set.</summary>
    public Task<string> RenderToSvgAsync() => RenderToSvgAsync(Document, JS).AsTask();

    public static async ValueTask<string> RenderToSvgAsync(GedcomDocument? document, IJSRuntime js)
    {
        if (document is null || document.Individuals.Count == 0)
        {
            return EmptySvg("No individuals.");
        }

        var nodes = new List<NodeJson>();
        foreach (var ind in document.Individuals)
        {
            nodes.Add(new NodeJson
            {
                Id = IndividualKey(ind.Id),
                Width = NODE_WIDTH,
                Height = NODE_HEIGHT,
            });
        }

        foreach (var fam in document.Families)
        {
            nodes.Add(new NodeJson
            {
                Id = FamilyKey(fam.Id),
                Width = FamilyNodeSize,
                Height = FamilyNodeSize,
            });
        }

        var edges = new List<EdgeJson>();
        foreach (var fam in document.Families)
        {
            var fk = FamilyKey(fam.Id);
            if (!string.IsNullOrEmpty(fam.HusbandId))
            {
                edges.Add(new EdgeJson { From = IndividualKey(fam.HusbandId!), To = fk });
            }

            if (!string.IsNullOrEmpty(fam.WifeId))
            {
                edges.Add(new EdgeJson { From = IndividualKey(fam.WifeId!), To = fk });
            }

            foreach (var c in fam.ChildrenIds)
            {
                if (string.IsNullOrEmpty(c))
                {
                    continue;
                }

                edges.Add(new EdgeJson { From = fk, To = IndividualKey(c) });
            }
        }

        if (nodes.Count == 0)
        {
            return EmptySvg("No nodes.");
        }

        var nodesJson = JsonSerializer.Serialize(nodes, JsonOpts);
        var edgesJson = JsonSerializer.Serialize(edges, JsonOpts);

        string resultJson;
        try
        {
            resultJson = await js.InvokeAsync<string>(
                "KorenyDagre.computeLayout",
                nodesJson,
                edgesJson,
                NODE_WIDTH,
                NODE_HEIGHT);
        }
        catch (JSException)
        {
            return EmptySvg("Layout failed (is Dagre loaded?).");
        }

        var layout = JsonSerializer.Deserialize<DagreLayoutResult>(resultJson, JsonOpts);
        if (layout?.Nodes is null || layout.Nodes.Count == 0)
        {
            return EmptySvg("No layout.");
        }

        var positions = new Dictionary<string, (double X, double Y)>(StringComparer.Ordinal);
        foreach (var n in layout.Nodes)
        {
            positions[n.Id] = (n.X, n.Y);
        }

        var minX = double.PositiveInfinity;
        var minY = double.PositiveInfinity;
        var maxX = double.NegativeInfinity;
        var maxY = double.NegativeInfinity;

        void IncludeRect(double x, double y, double w, double h)
        {
            minX = Math.Min(minX, x);
            minY = Math.Min(minY, y);
            maxX = Math.Max(maxX, x + w);
            maxY = Math.Max(maxY, y + h);
        }

        void IncludePoint(double x, double y)
        {
            minX = Math.Min(minX, x);
            minY = Math.Min(minY, y);
            maxX = Math.Max(maxX, x);
            maxY = Math.Max(maxY, y);
        }

        foreach (var ind in document.Individuals)
        {
            if (!positions.TryGetValue(IndividualKey(ind.Id), out var p))
            {
                continue;
            }

            IncludeRect(p.X, p.Y, NODE_WIDTH, NODE_HEIGHT);
        }

        foreach (var fam in document.Families)
        {
            if (!positions.TryGetValue(FamilyKey(fam.Id), out var fp))
            {
                continue;
            }

            IncludeRect(fp.X, fp.Y, FamilyNodeSize, FamilyNodeSize);
        }

        foreach (var fam in document.Families)
        {
            if (!positions.TryGetValue(FamilyKey(fam.Id), out var pF))
            {
                continue;
            }

            if (!string.IsNullOrEmpty(fam.HusbandId)
                && positions.TryGetValue(IndividualKey(fam.HusbandId!), out var pH))
            {
                IncludeOrthogonalParentToFamilyBounds(pH, pF, IncludePoint);
            }

            if (!string.IsNullOrEmpty(fam.WifeId)
                && positions.TryGetValue(IndividualKey(fam.WifeId!), out var pW))
            {
                IncludeOrthogonalParentToFamilyBounds(pW, pF, IncludePoint);
            }

            foreach (var c in fam.ChildrenIds)
            {
                if (string.IsNullOrEmpty(c))
                {
                    continue;
                }

                if (!positions.TryGetValue(IndividualKey(c), out var pC))
                {
                    continue;
                }

                IncludeOrthogonalFamilyToChildBounds(pF, pC, IncludePoint);
            }
        }

        if (double.IsInfinity(minX) || double.IsInfinity(minY))
        {
            return EmptySvg("No bounds.");
        }

        var ox = minX - Padding;
        var oy = minY - Padding;
        var width = maxX - minX + 2 * Padding;
        var height = maxY - minY + 2 * Padding;

        var sb = new StringBuilder();
        sb.Append(CultureInv($"""<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{height}" viewBox="0 0 {width} {height}">"""));
        // Veškerý obsah je v g.view — na tu skupinu připíná d3.zoom transformaci (graph-view.js),
        // a z jejího getBBox se počítá export. Bílé pozadí je uvnitř view, aby ho export pokryl.
        sb.Append("""<g class="view">""");
        sb.Append(CultureInv($"""<rect x="0" y="0" width="{width}" height="{height}" fill="white" />"""));
        sb.Append("""<g fill="none" stroke="#333" stroke-width="1.5">""");

        foreach (var fam in document.Families)
        {
            if (!positions.TryGetValue(FamilyKey(fam.Id), out var pF))
            {
                continue;
            }

            if (!string.IsNullOrEmpty(fam.HusbandId)
                && positions.TryGetValue(IndividualKey(fam.HusbandId!), out var pH))
            {
                sb.Append(CultureInv(
                    $"""<path d="{OrthogonalParentToFamilyPath(ox, oy, pH, pF)}" />"""));
            }

            if (!string.IsNullOrEmpty(fam.WifeId)
                && positions.TryGetValue(IndividualKey(fam.WifeId!), out var pW))
            {
                sb.Append(CultureInv(
                    $"""<path d="{OrthogonalParentToFamilyPath(ox, oy, pW, pF)}" />"""));
            }

            foreach (var c in fam.ChildrenIds)
            {
                if (string.IsNullOrEmpty(c))
                {
                    continue;
                }

                if (!positions.TryGetValue(IndividualKey(c), out var pC))
                {
                    continue;
                }

                sb.Append(CultureInv(
                    $"""<path d="{OrthogonalFamilyToChildPath(ox, oy, pF, pC)}" />"""));
            }
        }

        sb.Append("</g><g>");

        foreach (var fam in document.Families)
        {
            if (!positions.TryGetValue(FamilyKey(fam.Id), out var fp))
            {
                continue;
            }

            var fcx = fp.X + FamilyNodeSize * 0.5 - ox;
            var fcy = fp.Y + FamilyNodeSize * 0.5 - oy;
            sb.Append(CultureInv($"""<circle cx="{fcx}" cy="{fcy}" r="{FamilyDotR}" fill="#888780" stroke="none" />"""));
        }

        sb.Append("</g><g>");

        foreach (var ind in document.Individuals)
        {
            if (!positions.TryGetValue(IndividualKey(ind.Id), out var p))
            {
                continue;
            }

            var left = p.X - ox;
            var top = p.Y - oy;
            var cx = left + NODE_WIDTH * 0.5;
            var name = ind.FullName;
            name = string.IsNullOrWhiteSpace(name) ? ind.Id : name;
            // data-person-id nese surové xref ID; klik na skupinu vrací tuto hodnotu do Blazoru (reroot).
            sb.Append(CultureInv($"""<g data-person-id="{SvgEscape(ind.Id)}" style="cursor: pointer;">"""));
            sb.Append(CultureInv($"""<rect x="{left}" y="{top}" width="{NODE_WIDTH}" height="{NODE_HEIGHT}" fill="{FillFor(ind)}" stroke="#1a1a1a" />"""));
            sb.Append(CultureInv($"""<text x="{cx}" y="{top + NameLineY}" text-anchor="middle" font-size="13" fill="white">{SvgEscape(Truncate(name))}</text>"""));
            sb.Append(CultureInv($"""<text x="{cx}" y="{top + LifespanLineY}" text-anchor="middle" font-size="13" fill="white">{SvgEscape(FormatLife(ind))}</text>"""));
            sb.Append("</g>");
        }

        sb.Append("</g></g></svg>");
        return sb.ToString();
    }

    private static string CultureInv(FormattableString fs) => FormattableString.Invariant(fs);

    private static string IndividualKey(string id) => $"I{id}";

    private static string FamilyKey(string id) => $"F{id}";

    private static string OrthogonalParentToFamilyPath(double ox, double oy, (double X, double Y) parent, (double X, double Y) fam)
    {
        var parentCentreX = parent.X + NODE_WIDTH * 0.5 - ox;
        var parentBottom = parent.Y + NODE_HEIGHT - oy;
        var familyNodeX = fam.X - ox;
        var familyNodeY = fam.Y - oy;
        var ymid = (parentBottom + familyNodeY) * 0.5;
        return FormattableString.Invariant(
            $"M {N(parentCentreX)} {N(parentBottom)} L {N(parentCentreX)} {N(ymid)} L {N(familyNodeX)} {N(ymid)} L {N(familyNodeX)} {N(familyNodeY)}");
    }

    private static string OrthogonalFamilyToChildPath(double ox, double oy, (double X, double Y) fam, (double X, double Y) child)
    {
        var familyNodeX = fam.X - ox;
        var familyNodeY = fam.Y - oy;
        var childCentreX = child.X + NODE_WIDTH * 0.5 - ox;
        var childTop = child.Y - oy;
        var childMidY = (familyNodeY + childTop) * 0.5;
        return FormattableString.Invariant(
            $"M {N(familyNodeX)} {N(familyNodeY)} L {N(familyNodeX)} {N(childMidY)} L {N(childCentreX)} {N(childMidY)} L {N(childCentreX)} {N(childTop)}");
    }

    private static void IncludeOrthogonalParentToFamilyBounds(
        (double X, double Y) parent,
        (double X, double Y) fam,
        Action<double, double> includePoint)
    {
        var parentCentreX = parent.X + NODE_WIDTH * 0.5;
        var parentBottom = parent.Y + NODE_HEIGHT;
        var familyNodeX = fam.X;
        var familyNodeY = fam.Y;
        var ymid = (parentBottom + familyNodeY) * 0.5;
        includePoint(parentCentreX, parentBottom);
        includePoint(parentCentreX, ymid);
        includePoint(familyNodeX, ymid);
        includePoint(familyNodeX, familyNodeY);
    }

    private static void IncludeOrthogonalFamilyToChildBounds(
        (double X, double Y) fam,
        (double X, double Y) child,
        Action<double, double> includePoint)
    {
        var familyNodeX = fam.X;
        var familyNodeY = fam.Y;
        var childCentreX = child.X + NODE_WIDTH * 0.5;
        var childTop = child.Y;
        var childMidY = (familyNodeY + childTop) * 0.5;
        includePoint(familyNodeX, familyNodeY);
        includePoint(familyNodeX, childMidY);
        includePoint(childCentreX, childMidY);
        includePoint(childCentreX, childTop);
    }

    private static string N(double v) => v.ToString(System.Globalization.CultureInfo.InvariantCulture);

    private static string EmptySvg(string message)
    {
        var e = SvgEscape(message);
        return $"""<svg xmlns="http://www.w3.org/2000/svg" width="320" height="80" viewBox="0 0 320 80"><text x="160" y="44" text-anchor="middle" font-size="13" fill="#333">{e}</text></svg>""";
    }

    private static string FillFor(GedcomIndividual i)
    {
        if (i.Sex == "M")
        {
            return "#4A7FB5";
        }

        if (i.Sex == "F")
        {
            return "#9B2335";
        }

        return "#888780";
    }

    private static string FormatLife(GedcomIndividual i)
    {
        var b = i.Birth?.ParsedYear;
        var d = i.Death?.ParsedYear;
        if (b is not null && d is not null)
        {
            return $"{b}–{d}";
        }

        if (b is not null)
        {
            return $"{b}–";
        }

        if (d is not null)
        {
            return $"–{d}";
        }

        return "?";
    }

    private static string Truncate(string s)
    {
        if (s.Length <= MaxNameChars)
        {
            return s;
        }

        return s[..(MaxNameChars - 1)] + "…";
    }

    private static string SvgEscape(string s)
    {
        return s
            .Replace("&", "&amp;", StringComparison.Ordinal)
            .Replace("<", "&lt;", StringComparison.Ordinal)
            .Replace(">", "&gt;", StringComparison.Ordinal)
            .Replace("\"", "&quot;", StringComparison.Ordinal)
            .Replace("'", "&apos;", StringComparison.Ordinal);
    }

    private sealed class NodeJson
    {
        public string Id { get; set; } = "";
        public double Width { get; set; }
        public double Height { get; set; }
    }

    private sealed class EdgeJson
    {
        public string From { get; set; } = "";
        public string To { get; set; } = "";
    }

    private sealed class DagreLayoutResult
    {
        public List<DagreNodeLayout>? Nodes { get; set; }
    }

    private sealed class DagreNodeLayout
    {
        public string Id { get; set; } = "";
        public double X { get; set; }
        public double Y { get; set; }
    }
}
