@using Koreny.Models
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS

@* Živý „Celý graf": FullGraph vygeneruje SVG (Dagre + virtuální rodinné uzly), graph-view.js
   ho vloží do kontejneru a připne pan/zoom + klik. Layout se nemění, jen se zživotňuje. *@

<div id="@_elementId" style="width: 100%; height: 100%;"></div>

@code {
    private readonly string _elementId = $"koreny-graph-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private DotNetObjectReference<FullGraphView>? _selfRef;
    private bool _initialized;

    [Parameter]
    public GedcomDocument? Document { get; set; }

    [Parameter]
    public EventCallback<string> OnPersonSelected { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || Document is null || Document.Individuals.Count == 0)
        {
            return;
        }

        var svg = await FullGraph.RenderToSvgAsync(Document, JS);
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/graph-view.js");
        _selfRef = DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("init", _elementId, svg, _selfRef);
        _initialized = true;
    }

    [JSInvokable]
    public Task OnPersonClicked(string id) => OnPersonSelected.InvokeAsync(id);

    /// <summary>Samostatné SVG celého grafu (nezávislé na pan/zoom); null, dokud graf nestojí.</summary>
    public async Task<string?> ExportSvgAsync()
    {
        if (_module is null || !_initialized)
        {
            return null;
        }

        return await _module.InvokeAsync<string>("exportSvg", _elementId);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module is not null)
            {
                if (_initialized)
                {
                    await _module.InvokeVoidAsync("destroy", _elementId);
                }

                await _module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException)
        {
            // Okruh je pryč (reload/zavření) — JS strana zmizela i s DOM, není co uklízet.
        }

        _selfRef?.Dispose();
        _selfRef = null;
        _module = null;
    }
}
